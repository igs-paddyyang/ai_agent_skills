<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Ocean King Proposal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .page { page-break-after: always; }
  </style>
</head>
<body class="bg-gray-900 text-white">

  <!-- HERO PAGE -->
  <section class="page h-screen flex flex-col justify-center items-center text-center bg-gradient-to-br from-blue-900 to-black">
    <h1 class="text-6xl font-bold mb-6">Ocean King</h1>
    <p class="text-xl text-gray-300">Next-Gen Arcade Fish Shooting Experience</p>
  </section>

  <!-- FEATURES -->
  <section class="page p-16">
    <h2 class="text-4xl font-bold mb-10">Core Features</h2>
    <div class="grid grid-cols-2 gap-10">
      <div class="bg-gray-800 p-6 rounded-2xl shadow-lg">
        <h3 class="text-2xl font-semibold mb-2">Multiplayer Combat</h3>
        <p>Up to 10 players in real-time competitive shooting.</p>
      </div>
      <div class="bg-gray-800 p-6 rounded-2xl shadow-lg">
        <h3 class="text-2xl font-semibold mb-2">Boss Battles</h3>
        <p>Epic encounters with massive reward multipliers.</p>
      </div>
    </div>
  </section>

  <!-- GAMEPLAY -->
  <section class="page p-16">
    <h2 class="text-4xl font-bold mb-10">Gameplay Loop</h2>
    <div class="bg-gray-800 p-10 rounded-2xl">
      <p class="text-lg">Coin → Shoot → Capture → Earn → Repeat</p>
    </div>
  </section>

</body>
</html>
