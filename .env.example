# ============================================
# AI Agent Skills Workshop — 環境變數設定範例
# 複製此檔案為 .env 並填入你的金鑰
# cp .env.example .env
# ============================================

# [必要] Gemini API 金鑰
# 從 Google AI Studio 取得：https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# [必要] 技能定義路徑（預設值即可）
SKILL_PATH=.agent/skills

# [選用] Agent 配置
AGENT_NAME=MyAgent
AGENT_ROLE=GameDevArchitect

# [選用] ClawdBot — Telegram Bot 模組
# 從 @BotFather 取得：https://t.me/BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here
DATABASE_PATH=clawdbot/data/brain.db
